{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://demo.local/contracts/evaluation_task.schema.json",
  "title": "DEMO isolated evaluation task",
  "type": "object",
  "required": [
    "eval_id",
    "sample_id",
    "task_type",
    "prompt",
    "reference_answer",
    "rubric",
    "source_work_id",
    "source_author_id",
    "work_id",
    "author_id",
    "source_id",
    "document_id",
    "rights_record_id",
    "content_sha256",
    "dataset_version",
    "eval_version",
    "shard_id",
    "split",
    "isolation_assertion",
    "demo"
  ],
  "properties": {
    "eval_id": {"type": "string", "pattern": "^EVAL-[0-9]{3}$"},
    "split": {"const": "evaluation"},
    "eval_version": {"type": "string", "minLength": 1},
    "demo": {"const": true}
  },
  "additionalProperties": true
}
