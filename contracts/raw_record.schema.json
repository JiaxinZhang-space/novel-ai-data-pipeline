{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://demo.local/contracts/raw_record.schema.json",
  "title": "DEMO raw novel record",
  "type": "object",
  "required": [
    "record_id",
    "source_id",
    "document_id",
    "rights_record_id",
    "author_id",
    "work_id",
    "title",
    "text",
    "rights",
    "demo",
    "demo_marker"
  ],
  "properties": {
    "record_id": {"type": "string", "pattern": "^RAW-[0-9]{3}$"},
    "source_id": {"type": "string", "minLength": 1},
    "document_id": {"type": "string", "minLength": 1},
    "rights_record_id": {"type": "string", "minLength": 1},
    "author_id": {"type": "string", "minLength": 1},
    "work_id": {"type": "string", "minLength": 1},
    "title": {"type": "string", "minLength": 1},
    "text": {"type": "string", "minLength": 1},
    "language": {"const": "zh-CN"},
    "demo": {"const": true},
    "demo_marker": {"const": "DEMO_SYNTHETIC_NOT_REAL_WORLD_EVIDENCE"},
    "rights": {
      "type": "object",
      "required": [
        "contract_id",
        "consent_confirmed",
        "license_scope",
        "status",
        "valid_from",
        "valid_until",
        "demo"
      ],
      "properties": {
        "contract_id": {"type": "string"},
        "consent_confirmed": {"type": "boolean"},
        "license_scope": {"type": "array", "items": {"type": "string"}},
        "status": {"type": "string"},
        "valid_from": {"type": "string", "format": "date"},
        "valid_until": {"type": "string", "format": "date"},
        "demo": {"const": true}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

